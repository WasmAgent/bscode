{
  "name": "@bscode/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "test": "bun test --isolate",
    "test:watch": "bun test --watch --isolate",
    "typecheck": "tsc --noEmit",
    "deploy": "bunx opennextjs-cloudflare build && bunx wrangler deploy",
    "deploy:dry-run": "bunx opennextjs-cloudflare build && bunx wrangler deploy --dry-run --outdir=.open-next/dry-run",
    "preview": "bunx opennextjs-cloudflare build && bunx wrangler dev"
  },
  "dependencies": {
    "@wasmagent/react": "workspace:*",
    "@wasmagent/ui-cards": "workspace:*",
    "@wasmagent/ui-cards-react": "workspace:*",
    "@monaco-editor/react": "^4.6.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "@terrastruct/d2": "^0.1.33",
    "@webcontainer/api": "^1.6.4",
    "docx": "^9.7.1",
    "idb-keyval": "^6.2.5",
    "jszip": "^3.10.1",
    "next": "^15.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0"
  }
}
