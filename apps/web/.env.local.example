# bscode web frontend — copy to .env.local for local dev
# See ../.env.example for Worker (backend) environment variables.

# URL of the bscode Worker (backend).
# Local dev: wrangler dev runs on 8787 by default.
NEXT_PUBLIC_WORKER_URL=http://localhost:8787

# GitHub OAuth App credentials (optional — only needed for GitHub import feature)
# Create at: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: http://localhost:3000/api/github/callback
# NEXT_PUBLIC_GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
