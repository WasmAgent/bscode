{
  "name": "@bscode/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "bun --watch --env-file=.dev.vars src/server.node.ts",
    "dev:wrangler": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@agentkit-js/agent-prompts": "workspace:*",
    "@agentkit-js/core": "workspace:*",
    "@agentkit-js/kernel-pyodide": "workspace:*",
    "@agentkit-js/kernel-quickjs": "workspace:*",
    "@agentkit-js/kernel-remote": "workspace:*",
    "@agentkit-js/mcp-server": "workspace:*",
    "@agentkit-js/model-anthropic": "workspace:*",
    "@agentkit-js/model-deepseek": "workspace:*",
    "@agentkit-js/model-doubao": "workspace:*",
    "@agentkit-js/model-openai": "workspace:*",
    "@agentkit-js/tools-browser": "workspace:*",
    "@agentkit-js/tools-rag": "workspace:*",
    "@hono/node-server": "^2.0.4",
    "@jitl/quickjs-wasmfile-release-sync": "0.32.0",
    "diff": "^9.0.0",
    "hono": "^4.6.0",
    "pyodide": "0.29.4",
    "quickjs-emscripten-core": "0.32.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241224.0",
    "@types/node": "^25.9.2",
    "@vitest/coverage-v8": "^4.1.8",
    "bun-types": "^1.3.14",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8",
    "wrangler": "^3.93.0"
  }
}
